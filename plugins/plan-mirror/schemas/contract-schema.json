{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "revision", "goal", "requirements", "success_criteria", "constraints", "out_of_scope", "decisions"],
  "properties": {
    "schema_version": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "goal": { "$ref": "#/$defs/item" },
    "requirements": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/item" } },
    "success_criteria": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "constraints": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "out_of_scope": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/item" } }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string" }
      }
    }
  }
}
